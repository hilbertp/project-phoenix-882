# Copy this file to .env or .env.local for local-only values.
# Do not commit real secrets.

PHOENIX_POSTGRES_DB=phoenix
PHOENIX_POSTGRES_USER=phoenix
PHOENIX_POSTGRES_PASSWORD=phoenix-local-only
PHOENIX_DATABASE_URL=postgresql://phoenix:phoenix-local-only@postgres:5432/phoenix
PHOENIX_DATA_DIR=/storage/data
PHOENIX_ARTIFACTS_DIR=/storage/artifacts
